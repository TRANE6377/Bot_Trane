# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_bot_token_here

# Твой Telegram User ID (узнать у @userinfobot)
OWNER_ID=your_telegram_user_id

# Anthropic API Key (для суммаризации новостей)
# Получить на: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key

# Для чтения Telegram-каналов (опционально)
# Получить на: https://my.telegram.org/apps
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_PHONE=+7XXXXXXXXXX

# Настройки
TIMEZONE=Europe/Moscow
MORNING_TIME=08:00
EVENING_TIME=20:00
DATABASE_PATH=bot_data.db
TELETHON_SESSION=user_session
